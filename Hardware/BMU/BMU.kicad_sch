	(text "3. BMU-BQ79600\n\nCore function:\nInterfaces the MCU with the external battery-monitor daisy-chain network.\n\nShort version for page 1:\nBQ79600 host interface\nConnects STM32 to external battery monitor chain\nHandles daisy-chain communication"
		(exclude_from_sim no)
		(at 294.132 111.76 0)
		(effects
			(font
				(size 2.032 2.032)
			)
			(justify left)
		)
		(uuid "3a0563fb-172d-4a3b-ac5d-65c9da6353b1")
	)
	(text "4. BMU-CAN\n\nCore function:\nProvides the physical CAN-FD bus interface between the BMU and vehicle ECU.\n\nShort version for page 1:\nCAN-FD transceiver interface\nConverts MCU signals to CAN bus levels\nConnects BMU to ECU / vehicle network"
		(exclude_from_sim no)
		(at 293.624 145.542 0)
		(effects
			(font
				(size 2.032 2.032)
			)
			(justify left)
		)
		(uuid "8c6e16ed-add1-41a2-b5c2-5c1af0afece8")
	)
	(text "2. BMU-MCU\n\nCore function:\nMain STM32 controller for BMU logic, diagnostics, and communications.\n\nShort version for page 1:\nMain STM32 control page\nExecutes BMU control and monitoring logic\nInterfaces with BQ, CAN, and external shunt board"
		(exclude_from_sim no)
		(at 294.386 77.724 0)
		(effects
			(font
				(size 2.032 2.032)
			)
			(justify left)
		)
		(uuid "adf212c6-65c6-45fe-9126-33a46fa5c770")
	)
	(text "TO ECU\n"
