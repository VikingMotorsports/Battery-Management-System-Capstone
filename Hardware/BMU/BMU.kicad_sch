	(text "2. BMU-BQ79600\n\nCore function:\nImplements the isolated BQ79600 host bridge \nbetween the MCU and the external battery-monitor daisy-chain / ring network.\n\nShort version for page 1:\nIsolated BQ79600 host bridge interface\nConnects STM32 to external battery monitor chain\nHandles daisy-chain / ring communication"
		(exclude_from_sim no)
		(at 292.354 80.264 0)
		(effects
			(font
				(size 2.032 2.032)
			)
			(justify left)
		)
		(uuid "3a0563fb-172d-4a3b-ac5d-65c9da6353b1")
	)
	(text "-COM connectors follow the TI EVM 4-pin format \n	for high-side and low-side daisy-chain interfaces.\n-Each connector carries one differential COM pair only; \n	unused pins are left NC."
		(exclude_from_sim no)
		(at 97.79 167.64 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "689954c5-f6a4-4276-a040-55841478b4ca")
	)
	(text "4. BMU-CAN\n\nCore function:\nProvides the physical CAN-FD bus interface between the BMU and vehicle ECU.\n\nShort version for page 1:\nCAN-FD transceiver interface\nConverts MCU signals to CAN bus levels\nConnects BMU to ECU / vehicle network"
		(exclude_from_sim no)
		(at 291.846 148.082 0)
		(effects
			(font
				(size 2.032 2.032)
			)
			(justify left)
		)
		(uuid "8c6e16ed-add1-41a2-b5c2-5c1af0afece8")
	)
	(text "3. BMU-MCU\n\nCore function:\nMain STM32 controller for BMU logic, diagnostics, and communications.\n\nShort version for page 1:\nMain STM32 control page\nExecutes BMU control and monitoring logic\nInterfaces with BQ, CAN, and external shunt board"
		(exclude_from_sim no)
		(at 292.1 114.808 0)
		(effects
			(font
				(size 2.032 2.032)
			)
			(justify left)
		)
		(uuid "adf212c6-65c6-45fe-9126-33a46fa5c770")
	)
	(text "TO ECU\n"
		(exclude_from_sim no)
		(at 271.526 143.51 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "cda0ba5b-4ef2-45ba-adcc-9c9e941e4537")
	)
	(text "1. BMU-POWER\n\nCore function:\nConditions the 12 V input and generates the regulated 5 V and 3.3 V rails.\n\nShort version for page 1:\n12 V input conditioning and protection\nGenerates 5 V and 3.3 V rails\nSupplies power to BMU circuits"
		(exclude_from_sim no)
		(at 292.862 46.228 0)
		(effects
			(font
				(size 2.032 2.032)
			)
			(justify left)
		)
		(uuid "d92171e3-4207-439c-8e4d-3e2560cdbd94")
	)
	(text "From SHUNT\n"
		(exclude_from_sim no)
		(at 241.808 175.006 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "e48130a6-b692-4aba-b776-4c5e8e817183")
	)
	(text "BQ79616\n"
		(exclude_from_sim no)
		(at 93.98 120.65 0)
		(effects
			(font
				(size 2.54 2.54)
			)
		)
		(uuid "fab5aac8-6b7f-4d6a-82b6-5e3ce635403b")
	)
	(text "Optional module, if you keep it later\n5. BMU-SAFETY\n\nCore function:\nRoutes BMU fault and status signals to external shutdown or safety circuits.\n\nShort version for page 1:\nSafety / shutdown interface\nRoutes fault and status signals\nOptional external safety path"
		(exclude_from_sim no)
		(at 291.338 185.928 0)
		(effects
			(font
				(size 2.032 2.032)
			)
			(justify left)
		)
		(uuid "fc614365-f0e9-419a-87c9-94d467b865a2")
	)
